# ============================================================
# 售后助手 - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# ---- LLM 配置（必填）----
# DeepSeek API Key（推荐，便宜好用）
# 注册获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# 可选：切换模型提供商
# LLM_PROVIDER=deepseek  (默认，可选 openai / anthropic)
LLM_PROVIDER=deepseek

# ---- 服务器配置 ----
SERVER_PORT=5051

# ---- 企业微信配置（可选）----
# 智能机器人 BotID 和 Secret
# WECOM_BOT_ID=
# WECOM_BOT_SECRET=

# 旧版回调模式（如不用智能机器人则忽略）
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_APP_SECRET=
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=
